<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext ws:// for LAN/VPN setups where the hub
         does not have TLS enabled. OkHttp resolves hostnames before
         connecting, so we must list every IP literal the user might
         type (private ranges) plus the Android-emulator gateway. -->
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
