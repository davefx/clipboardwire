# clipboardwire server configuration.
#
# Install:   sudo cp clipboardwire.env.example /etc/clipboardwire/clipboardwire.env
# Then edit the file, set a real password, and run:
#   sudo systemctl enable --now clipboardwire

# --- Required ---

# HTTP Basic auth credentials. Both must be set, neither can be empty.
CLIPBOARDWIRE_USER=alice
CLIPBOARDWIRE_PASSWORD=changeme

# Alternatively, read the password from a file (mutually exclusive with
# CLIPBOARDWIRE_PASSWORD above; comment out PASSWORD if you use this):
# CLIPBOARDWIRE_PASSWORD_FILE=/etc/clipboardwire/password

# --- Optional ---

# Bind address. Default: 0.0.0.0:8484. Bind to loopback if you front it
# with a reverse proxy on the same host:
# CLIPBOARDWIRE_BIND=127.0.0.1:8484

# Max concurrent connected clients. Default: 64.
# CLIPBOARDWIRE_MAX_CONNS=64

# Max WebSocket frame size in bytes. Default: 10485760 (10 MiB).
# CLIPBOARDWIRE_MAX_FRAME=10485760

# Tracing-subscriber filter. Default: clipboardwire_core=info.
# RUST_LOG=clipboardwire=info,clipboardwire_core=info
