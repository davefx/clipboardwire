<?xml version='1.0' encoding='windows-1252'?>
<!--
  clipboardwire WiX 3 source.

  Builds a per-machine x64 MSI that installs clipboardwire.exe to
  %ProgramFiles%\clipboardwire\ and prepends the install dir to the system
  PATH so the binary is on PATH from any shell.

  Build: see .github/workflows/release.yml for the cargo wix invocation.

  GUID policy:
  * UpgradeCode is stable forever; never change it (rotating it would
    break MSI's upgrade detection).
  * Per-component GUIDs are stable per file path; keep them stable across
    versions so MajorUpgrade removes the old before installing the new.

  License: GPL-3.0-or-later.
-->
<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>
  <Product
    Id='*'
    Name='clipboardwire'
    UpgradeCode='44487CCC-DAC6-46DA-A956-EC472C1EE7C6'
    Manufacturer='davefx'
    Language='1033'
    Codepage='1252'
    Version='$(var.Version)'>

    <Package
      Id='*'
      Keywords='Installer'
      Description='clipboardwire â€” clipboard sync over WebSocket'
      Manufacturer='davefx'
      InstallerVersion='450'
      Languages='1033'
      Compressed='yes'
      InstallScope='perMachine'
      SummaryCodepage='1252'/>

    <MajorUpgrade
      Schedule='afterInstallInitialize'
      DowngradeErrorMessage='A newer version of clipboardwire is already installed.'/>

    <Media Id='1' Cabinet='media1.cab' EmbedCab='yes' DiskPrompt='CD-ROM #1'/>
    <Property Id='DiskPrompt' Value='clipboardwire Installation'/>

    <Directory Id='TARGETDIR' Name='SourceDir'>
      <Directory Id='ProgramFiles64Folder' Name='PFiles'>
        <Directory Id='APPLICATIONFOLDER' Name='clipboardwire'>
          <Component
            Id='Cmp_Binary'
            Guid='12B24AAB-A7DC-4563-B752-21DAACE69753'
            Win64='yes'>
            <File
              Id='File_Binary'
              Name='clipboardwire.exe'
              DiskId='1'
              Source='$(var.CargoTargetBinDir)\clipboardwire.exe'
              KeyPath='yes'/>
            <Environment
              Id='PATH'
              Name='PATH'
              Value='[APPLICATIONFOLDER]'
              Permanent='no'
              Part='last'
              Action='set'
              System='yes'/>
          </Component>

          <Component
            Id='Cmp_License'
            Guid='3FD015D7-36E8-4642-88BC-6D9D2274FBC7'
            Win64='yes'>
            <File
              Id='File_License'
              Name='LICENSE.txt'
              DiskId='1'
              Source='$(var.CargoTargetBinDir)\..\..\LICENSE'
              KeyPath='yes'/>
          </Component>
        </Directory>
      </Directory>

      <Directory Id='ProgramMenuFolder'>
        <Directory Id='AppShortcutFolder' Name='clipboardwire'>
          <Component
            Id='Cmp_StartMenuShortcut'
            Guid='3B22DC68-7C0C-4522-93A4-F171FFDA0C08'
            Win64='yes'>
            <Shortcut
              Id='StartMenuShortcut'
              Name='clipboardwire (Tray)'
              Description='Sync clipboards between trusted devices'
              Target='[APPLICATIONFOLDER]clipboardwire.exe'
              Arguments='connect --tray'
              WorkingDirectory='APPLICATIONFOLDER'/>
            <RemoveFolder Id='RemoveAppShortcutFolder' On='uninstall'/>
            <RegistryValue
              Root='HKCU'
              Key='Software\clipboardwire'
              Name='start_menu_shortcut'
              Type='integer'
              Value='1'
              KeyPath='yes'/>
          </Component>
        </Directory>
      </Directory>

      <Directory Id='DesktopFolder' Name='Desktop'>
        <Component
          Id='Cmp_DesktopShortcut'
          Guid='E4555693-3282-40FE-AEDC-5106D37DDDCA'
          Win64='yes'>
          <Shortcut
            Id='DesktopShortcut'
            Name='clipboardwire'
            Description='Sync clipboards between trusted devices'
            Target='[APPLICATIONFOLDER]clipboardwire.exe'
            Arguments='connect --tray'
            WorkingDirectory='APPLICATIONFOLDER'/>
          <RegistryValue
            Root='HKCU'
            Key='Software\clipboardwire'
            Name='desktop_shortcut'
            Type='integer'
            Value='1'
            KeyPath='yes'/>
        </Component>
      </Directory>
    </Directory>

    <Component
      Id='Cmp_AutoStart'
      Guid='9889B3DB-7BD1-420D-BE4F-CF5E8AF68A86'
      Win64='yes'
      Directory='APPLICATIONFOLDER'>
      <RegistryValue
        Root='HKCU'
        Key='Software\Microsoft\Windows\CurrentVersion\Run'
        Name='clipboardwire'
        Type='string'
        Value='"[APPLICATIONFOLDER]clipboardwire.exe" connect --tray'
        KeyPath='yes'/>
    </Component>

    <Feature
      Id='Binaries'
      Title='clipboardwire'
      Description='The clipboardwire binary and its license.'
      Level='1'
      ConfigurableDirectory='APPLICATIONFOLDER'
      AllowAdvertise='no'
      Display='expand'
      Absent='disallow'>
      <ComponentRef Id='Cmp_Binary'/>
      <ComponentRef Id='Cmp_License'/>
    </Feature>

    <Feature
      Id='StartMenuShortcut'
      Title='Start Menu shortcut'
      Description='Add a Start Menu entry for clipboardwire (Tray).'
      Level='1'
      AllowAdvertise='no'>
      <ComponentRef Id='Cmp_StartMenuShortcut'/>
    </Feature>

    <Feature
      Id='DesktopShortcut'
      Title='Desktop shortcut'
      Description='Add a Desktop shortcut for clipboardwire.'
      Level='1'
      AllowAdvertise='no'>
      <ComponentRef Id='Cmp_DesktopShortcut'/>
    </Feature>

    <Feature
      Id='AutoStart'
      Title='Start at login'
      Description='Launch the tray automatically when the current user signs in.'
      Level='1'
      AllowAdvertise='no'>
      <ComponentRef Id='Cmp_AutoStart'/>
    </Feature>

    <SetProperty Id='ARPINSTALLLOCATION' Value='[APPLICATIONFOLDER]' After='CostFinalize'/>
    <Property Id='ARPHELPLINK' Value='https://github.com/davefx/clipboardwire'/>

    <UI>
      <UIRef Id='WixUI_Minimal'/>
    </UI>
    <WixVariable Id='WixUILicenseRtf' Value='$(var.CargoTargetBinDir)\..\..\cli\wix\License.rtf'/>
  </Product>
</Wix>
